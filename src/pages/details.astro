---
import Layout from "../layouts/Layout.astro";
import Entry from "../components/Entry.astro";
import data from "../data/data.json" with { type: "json" };

const languages = data.skills.technical[0].split(":")[1];
const frameworks = data.skills.technical[1].split(":")[1];
---

<Layout>
  <section>
    <div class="markdown-body">
      <p>
        Ég hef mjög mikinn áhuga á reikniritum og bakendaforritun en á það
        einnig til að takast á við hönnun og framendaforritun, uppáhalds
        tungumálin mín eru C og Java en ég hef þó reynslu af mun fleiri
        forritunarmálum og þróunarumhverfum sem sjá má hér á eftir, endilega
        skoðaðu reynslu og menntun mína þar á eftir
      </p>
      <p class="sub">{languages}</p>
      <p class="sub">{frameworks}</p>
    </div>
  </section>
  <section>
    {
      data.experience.map((e) => (
        <Entry
          title={e.title}
          subtitle={e.company}
          body={e.description}
          date={e.period}
        />
      ))
    }
  </section>
</Layout>
